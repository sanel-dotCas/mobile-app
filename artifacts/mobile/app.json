{
  "expo": {
    "name": "IGMMA DMS",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "bundleIdentifier": "com.igmma.dms",
      "supportsTablet": false
    },
    "android": {
      "package": "com.igmma.dms"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": false
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Feather.ttf"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1d4ed8",
          "sounds": []
        }
      ]
    ],
       "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": d7b60435-3d66-41f3-b824-bed20ef4e189
      }
    },
    "updates": {
      "url": "https://u.expo.dev/PASTE-YOUR-PROJECT-ID-HERE"
    }
    }
  }
}
